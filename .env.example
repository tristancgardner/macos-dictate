# .env.local configuration for macos-dictate
# Copy this file to .env.local and fill in your paths.
# .env.local is gitignored and will never be committed.

# Cmd+F1: Append transcription as a bullet point to this file.
# Set to the absolute path of your primary TODO or notes file.
APPEND_BULLET_FILE=/path/to/your/primary_todo.md

# Alt+F1: Append transcription as a bullet point to this second file.
# Set to the absolute path of your secondary TODO or notes file.
APPEND_BULLET_FILE_2=/path/to/your/secondary_todo.md
